[node name="StretchXRow" type="HBoxContainer" parent="Content/StretchSection"]

[node name="StretchXLabel" type="Label" parent="Content/StretchSection/StretchXRow"]
custom_minimum_size = Vector2(20, 0)
text = "X"

[node name="StretchXSlider" type="HSlider" parent="Content/StretchSection/StretchXRow"]
size_flags_horizontal = 3
min_value = 0.1
max_value = 3.0
step = 0.05
value = 1.0

[node name="StretchXValue" type="Label" parent="Content/StretchSection/StretchXRow"]
custom_minimum_size = Vector2(48, 0)
text = "1.00"
horizontal_alignment = 2

[node name="StretchYRow" type="HBoxContainer" parent="Content/StretchSection"]

[node name="StretchYLabel" type="Label" parent="Content/StretchSection/StretchYRow"]
custom_minimum_size = Vector2(20, 0)
text = "Y"

[node name="StretchYSlider" type="HSlider" parent="Content/StretchSection/StretchYRow"]
size_flags_horizontal = 3
min_value = 0.1
max_value = 3.0
step = 0.05
value = 1.0

[node name="StretchYValue" type="Label" parent="Content/StretchSection/StretchYRow"]
custom_minimum_size = Vector2(48, 0)
text = "1.00"
horizontal_alignment = 2

[node name="StretchZRow" type="HBoxContainer" parent="Content/StretchSection"]

[node name="StretchZLabel" type="Label" parent="Content/StretchSection/StretchZRow"]
custom_minimum_size = Vector2(20, 0)
text = "Z"

[node name="StretchZSlider" type="HSlider" parent="Content/StretchSection/StretchZRow"]
size_flags_horizontal = 3
min_value = 0.1
max_value = 3.0
step = 0.05
value = 1.0

[node name="StretchZValue" type="Label" parent="Content/StretchSection/StretchZRow"]
custom_minimum_size = Vector2(48, 0)
text = "1.00"
horizontal_alignment = 2

[node name="Separator2" type="HSeparator" parent="Content"]

[node name="TwistSection" type="VBoxContainer" parent="Content"]
theme_override_constants/separation = 4

[node name="TwistTitle" type="Label" parent="Content/TwistSection"]
text = "Twist"

[node name="TwistRow" type="HBoxContainer" parent="Content/TwistSection"]

[node name="TwistSlider" type="HSlider" parent="Content/TwistSection/TwistRow"]
size_flags_horizontal = 3
min_value = -180.0
max_value = 180.0
step = 1.0
value = 0.0

[node name="TwistValue" type="Label" parent="Content/TwistSection/TwistRow"]
