[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/editor/Properties.gd" id="1"]

[node name="Properties" type="MarginContainer"]
anchor_right = 1.0
anchor_bottom = 1.0
theme_override_constants/margin_left = 8
theme_override_constants/margin_right = 8
theme_override_constants/margin_top = 8
theme_override_constants/margin_bottom = 8
script = ExtResource("1")

[node name="EmptyLabel" type="Label" parent="."]
text = "Select a part to inspect"
horizontal_alignment = 1
vertical_alignment = 1
modulate = Color(1, 1, 1, 0.5)

[node name="Content" type="VBoxContainer" parent="."]
visible = false
theme_override_constants/separation = 10

[node name="Header" type="Label" parent="Content"]
text = "—"
autowrap_mode = 2
theme_override_font_sizes/font_size = 14

[node name="Separator1" type="HSeparator" parent="Content"]

[node name="StretchSection" type="VBoxContainer" parent="Content"]
theme_override_constants/separation = 4

[node name="StretchTitle" type="Label" parent="Content/StretchSection"]
